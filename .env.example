NEXT_PUBLIC_SITE_URL=https://example.com

# Resend (https://resend.com) — お問い合わせ / 体験申込フォームのメール送信に使用。
# RESEND_API_KEY 未設定時は /api/contact がメールを送らず、サーバーログのみに出力する（dev_log_only モード）。
RESEND_API_KEY=
# 送信元アドレス。Resend で domain verify 済みの場合のみ独自ドメインが使える。
# 未設定時は "Solvora <onboarding@resend.dev>"（Resend のテスト用送信元）にフォールバック。
CONTACT_EMAIL_FROM=
# 受信先アドレス。未設定時は morisan.yutakun@gmail.com にフォールバック。
CONTACT_EMAIL_TO=

# GA4 / Google Ads（クライアント側で参照するので NEXT_PUBLIC_*）。
# 未設定時はソース内のフォールバック値（G-WT6BZVH9YJ / AW-17966887751）が使われる。
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GADS_ID=
# Google Ads コンバージョン アクションのラベル（ダッシュボードで作成後に発行される）。
NEXT_PUBLIC_GADS_LABEL_TRIAL_CLICK=
NEXT_PUBLIC_GADS_LABEL_TRIAL_COMPLETE=
